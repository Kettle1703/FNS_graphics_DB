<Window x:Class="FNS_graphics.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Панель администратора"
        Height="760"
        Width="1040"
        MinHeight="660"
        MinWidth="900"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Background" Value="#FFF2F8F2" />
            <Setter Property="Foreground" Value="#FF1F3A2A" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderBrush" Value="#FFB6CCB8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="Height" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderBrush" Value="#FFB6CCB8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="Height" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="MinWidth" Value="130" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Background" Value="#FF70B07D" />
            <Setter Property="Foreground" Value="#FF193B26" />
            <Setter Property="BorderBrush" Value="#FF5A996A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="BorderBrush" Value="#FFC4DCC9" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="RowHeight" Value="28" />
            <Setter Property="ColumnHeaderHeight" Value="30" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="IsReadOnly" Value="True" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0">
                <TextBlock Text="Панель администратора"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="AdminInfoTextBlock"
                           Foreground="#FF3F5A45"
                           Margin="0" />
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Обновить"
                    x:Name="RefreshDatabaseButton"
                    Click="RefreshDatabase_Click"
                    Margin="8,4,0,0" />
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <WrapPanel Grid.Row="0">
                <Button x:Name="BlockUserButton"
                        Content="Заблокировать"
                        Click="BlockUser_Click" />
                <Button x:Name="UnblockUserButton"
                        Content="Разблокировать"
                        Click="UnblockUser_Click" />
                <Button x:Name="MakeAdminButton"
                        Content="Сделать админом"
                        Click="MakeAdmin_Click" />
                <Button x:Name="MakeUserButton"
                        Content="Сделать пользователем"
                        Click="MakeUser_Click"
                        MinWidth="190" />
            </WrapPanel>

            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Новый пароль"
                           VerticalAlignment="Center"
                           Margin="0,0,8,8" />
                <PasswordBox x:Name="ResetPasswordBox"
                             Grid.Column="1"
                             Margin="0,0,8,8" />
                <Button x:Name="ResetPasswordButton"
                        Grid.Column="2"
                        Content="Сбросить пароль"
                        Click="ResetPassword_Click"
                        MinWidth="170" />
                <TextBlock x:Name="SelectedUserTextBlock"
                           Grid.Column="3"
                           VerticalAlignment="Center"
                           Foreground="#FF3F5A45"
                           Margin="8,0,0,8" />
            </Grid>
        </Grid>

        <TabControl Grid.Row="2">
            <TabItem Header="Пользователи">
                <DataGrid x:Name="UsersDataGrid"
                          AutoGenerateColumns="False"
                          SelectionMode="Single"
                          SelectionChanged="UsersDataGrid_SelectionChanged">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding UserId}" Width="60" />
                        <DataGridTextColumn Header="Логин" Binding="{Binding Login}" Width="*" />
                        <DataGridTextColumn Header="Роль" Binding="{Binding RoleDisplay}" Width="130" />
                        <DataGridTextColumn Header="Статус" Binding="{Binding StateDisplay}" Width="130" />
                        <DataGridTextColumn Header="Всего" Binding="{Binding TotalRequests}" Width="80" />
                        <DataGridTextColumn Header="Шифр." Binding="{Binding EncryptRequests}" Width="80" />
                        <DataGridTextColumn Header="Дешифр." Binding="{Binding DecryptRequests}" Width="90" />
                        <DataGridTextColumn Header="Успех" Binding="{Binding SuccessfulRequests}" Width="80" />
                        <DataGridTextColumn Header="Ошибки" Binding="{Binding FailedRequests}" Width="80" />
                        <DataGridTextColumn Header="Последний запрос" Binding="{Binding LastRequestAt}" Width="155" />
                        <DataGridTextColumn Header="Последний вход" Binding="{Binding LastLoginAt}" Width="155" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="История запросов">
                <DataGrid x:Name="RequestHistoryDataGrid"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding RequestId}" Width="60" />
                        <DataGridTextColumn Header="Пользователь" Binding="{Binding Login}" Width="*" />
                        <DataGridTextColumn Header="Действие" Binding="{Binding Action}" Width="130" />
                        <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="110" />
                        <DataGridTextColumn Header="Вход" Binding="{Binding InputLength}" Width="80" />
                        <DataGridTextColumn Header="Выход" Binding="{Binding OutputLength}" Width="80" />
                        <DataGridTextColumn Header="Время" Binding="{Binding DurationMs}" Width="95" />
                        <DataGridTextColumn Header="Создано" Binding="{Binding CreatedAt}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="Действия администраторов">
                <DataGrid x:Name="AdminActionsDataGrid"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="ID" Binding="{Binding ActionId}" Width="60" />
                        <DataGridTextColumn Header="Админ" Binding="{Binding AdminLogin}" Width="*" />
                        <DataGridTextColumn Header="Пользователь" Binding="{Binding TargetLogin}" Width="*" />
                        <DataGridTextColumn Header="Действие" Binding="{Binding ActionDisplay}" Width="150" />
                        <DataGridTextColumn Header="Описание" Binding="{Binding Description}" Width="2*" />
                        <DataGridTextColumn Header="Создано" Binding="{Binding CreatedAt}" Width="160" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>

        <TextBlock x:Name="DatabaseStatusTextBlock"
                   Grid.Row="3"
                   Foreground="#FF2E6A42"
                   Margin="0,10,0,0" />
    </Grid>
</Window>
