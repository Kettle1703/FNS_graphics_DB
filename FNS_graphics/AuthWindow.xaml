<Window x:Class="FNS_graphics.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему"
        Height="520"
        Width="540"
        MinHeight="460"
        MinWidth="500"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <Style TargetType="Window">
            <Setter Property="FontFamily" Value="Bahnschrift" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Background" Value="#FFF2F8F2" />
            <Setter Property="Foreground" Value="#FF1F3A2A" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderBrush" Value="#FFB6CCB8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="Height" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="Margin" Value="0,0,0,12" />
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="BorderBrush" Value="#FFB6CCB8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Background" Value="#FFFFFFFF" />
            <Setter Property="Height" Value="34" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>

        <Style TargetType="Button">
            <Setter Property="MinWidth" Value="120" />
            <Setter Property="Height" Value="34" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="Background" Value="#FF70B07D" />
            <Setter Property="Foreground" Value="#FF193B26" />
            <Setter Property="BorderBrush" Value="#FF5A996A" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <Style x:Key="StatusTextBoxStyle" TargetType="TextBox">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#FF3F5A45" />
            <Setter Property="Height" Value="Auto" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="AcceptsReturn" Value="True" />
            <Setter Property="VerticalScrollBarVisibility" Value="Disabled" />
        </Style>
    </Window.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Авторизация"
                   FontSize="22"
                   FontWeight="SemiBold"
                   Margin="0,0,0,18" />

        <StackPanel Grid.Row="1">
            <TextBlock Text="Логин" />
            <TextBox x:Name="LoginTextBox" />
        </StackPanel>

        <StackPanel Grid.Row="2">
            <TextBlock Text="Пароль" />
            <PasswordBox x:Name="PasswordBox" />
        </StackPanel>

        <Border Grid.Row="3"
                Background="#FFFFFFFF"
                BorderBrush="#FFC4DCC9"
                BorderThickness="1"
                Padding="12"
                Margin="0,4,0,16"
                MinHeight="160">
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <TextBox x:Name="ConnectionStatusTextBlock"
                             Style="{StaticResource StatusTextBoxStyle}" />
                    <TextBox x:Name="UserStatusTextBlock"
                             Style="{StaticResource StatusTextBoxStyle}" />
                    <TextBox x:Name="PasswordStatusTextBlock"
                             Style="{StaticResource StatusTextBoxStyle}" />
                    <TextBox x:Name="WindowStatusTextBlock"
                             Style="{StaticResource StatusTextBoxStyle}"
                             Foreground="#FF8A3B2C"
                             Margin="0" />
                </StackPanel>
            </ScrollViewer>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="LoginButton"
                    Content="Войти"
                    Click="Login_Click"
                    IsDefault="True"
                    Margin="0,0,10,0" />
            <Button Content="Отмена"
                    Click="Cancel_Click"
                    IsCancel="True"
                    Background="#FFE4ECE5"
                    BorderBrush="#FFB6CCB8" />
        </StackPanel>
    </Grid>
</Window>
